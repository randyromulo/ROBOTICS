// RENDER LOOP
// ══════════════════════════════════════════
let lastT=0,fps=60,T=0;
window.addEventListener('error',e=>{if(e.message?.includes('ResizeObserver')){e.stopImmediatePropagation();e.preventDefault();}});

function animate(ts){
  requestAnimationFrame(animate);
  const dt=Math.min((ts-lastT)/1000,.05);lastT=ts;T+=dt;
  fps=Math.round(.93*fps+.07*(1/Math.max(dt,.001)));
  if(ts%700<18){document.getElementById('fps').textContent=Math.min(fps,60);document.getElementById('fpsLbl').textContent=Math.min(fps,60)+'FPS';}
  if(autoSpin&&drag===null)rotY+=dt*.4;
  rGroup.rotation.y=rotY;
  if(L.torso){
    if(L.lA){L.lA.rotation.z=0;L.lA.rotation.x=0;}
    if(L.rA){L.rA.rotation.z=0;L.rA.rotation.x=0;}
    if(L.head){L.head.rotation.y=0;L.head.rotation.x=0;}
    if(L.lL)L.lL.rotation.x=0;if(L.rL)L.rL.rotation.x=0;L.torso.rotation.z=0;
    switch(curAnim){
      case'idle':rGroup.position.y=.5+Math.sin(T*1.2)*.05;if(L.lA)L.lA.rotation.z=-.18+Math.sin(T*1.2)*.04;if(L.rA)L.rA.rotation.z=.18-Math.sin(T*1.2)*.04;if(L.head)L.head.rotation.x=Math.sin(T*.5)*.05;break;
      case'wave':rGroup.position.y=.5+Math.sin(T*1.5)*.04;if(L.rA){L.rA.rotation.z=.5+Math.sin(T*4)*.75;L.rA.rotation.x=Math.sin(T*2)*.2;}if(L.lA)L.lA.rotation.z=-.15;if(L.head)L.head.rotation.y=Math.sin(T*3)*.18;break;
      case'dance':rGroup.position.y=.5+Math.abs(Math.sin(T*3))*.28;if(L.lA){L.lA.rotation.z=-.4+Math.sin(T*3)*.85;L.lA.rotation.x=Math.cos(T*3)*.4;}if(L.rA){L.rA.rotation.z=.4-Math.sin(T*3)*.85;L.rA.rotation.x=-Math.cos(T*3)*.4;}if(L.lL)L.lL.rotation.x=Math.sin(T*3)*.3;if(L.rL)L.rL.rotation.x=-Math.sin(T*3)*.3;L.torso.rotation.z=Math.sin(T*3)*.1;break;
      case'scan':rGroup.position.y=.5;if(L.head){L.head.rotation.y=Math.sin(T*1.5)*.75;L.head.rotation.x=Math.sin(T*.7)*.2;}if(L.lA){L.lA.rotation.z=-.65;L.lA.rotation.x=Math.sin(T*1.2)*.3;}if(L.rA){L.rA.rotation.z=.65;L.rA.rotation.x=-Math.sin(T*1.2)*.3;}break;
      case'talk':rGroup.position.y=.5+Math.sin(T*2)*.03;if(L.head){L.head.rotation.y=Math.sin(T*1.8)*.1;L.head.rotation.x=.04;}if(L.lA)L.lA.rotation.z=-.22+Math.sin(T*2.5)*.1;if(L.rA)L.rA.rotation.z=.22-Math.sin(T*2.5)*.1;if(L.mouth&&isSpeaking)L.mouth.scale.y=1+Math.abs(Math.sin(T*9))*3;break;
    }
    if(curAnim!=='talk'&&L.mouth)L.mouth.scale.y=1;
  }
  cL.intensity=1.8+Math.sin(T*2)*.4;oL.intensity=1.2+Math.cos(T*1.5)*.3;
  renderer.render(scene,cam3d);
}

let rAF=null;
function onResize(){
  if(rAF)return;rAF=requestAnimationFrame(()=>{rAF=null;
    const w=canvas.clientWidth,h=canvas.clientHeight;
    if(w>0&&h>0){renderer.setSize(w,h,false);cam3d.aspect=w/h;cam3d.updateProjectionMatrix();}
    const cv=document.getElementById('camView');
    if(cv){camCvs.width=cv.clientWidth||1;camCvs.height=cv.clientHeight||1;}
  });
}
new ResizeObserver(onResize).observe(document.querySelector('.app'));
onResize();
if(window.speechSynthesis){speechSynthesis.getVoices();speechSynthesis.addEventListener('voiceschanged',()=>speechSynthesis.getVoices());}

// Boot
addSys('⚡ UNIT-7X systems online. Enter your Anthropic API key above to activate full AI.');
addSys('🔑 Get a FREE key at: console.anthropic.com → API Keys → Create Key');

if(API_KEY){
  addSys('✅ Saved API key found — UNIT-7X omniscient mode activating...');
  doGreet();
}

requestAnimationFrame(animate);
</script>
