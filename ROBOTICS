// CAMERA
// ══════════════════════════════════════════
let camStream=null,camActive=false,visInt=null;
const vid=document.getElementById('camVideo');
const camCvs=document.getElementById('camCanvas');

async function toggleCamera(){
  if(!camActive){
    try{
      camStream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment',width:{ideal:1280},height:{ideal:720}},audio:false});
      vid.srcObject=camStream;camActive=true;
      document.getElementById('camOff').style.display='none';
      document.getElementById('camToggle').textContent='⏹ CAM';
      document.getElementById('camToggle').classList.add('active');
      document.getElementById('camStat').textContent='ON';
      document.getElementById('camDot').className='dot g';
      document.getElementById('scanLine').style.display='block';
      addSys('📷 Camera ON — UNIT-7X can see and identify everything around you!');
      visInt=setInterval(()=>{if(camActive)silentAnalyze();},20000);
      setTimeout(()=>analyzeCamera(true),2200);
    }catch(e){addSys('⚠️ Camera permission denied. Please allow camera access in browser settings.');}
  } else {
    if(camStream)camStream.getTracks().forEach(t=>t.stop());
    vid.srcObject=null;camActive=false;
    document.getElementById('camOff').style.display='flex';
    document.getElementById('camToggle').textContent='▶ CAM';
    document.getElementById('camToggle').classList.remove('active');
    document.getElementById('camStat').textContent='OFF';
    document.getElementById('camDot').className='dot r';
    document.getElementById('scanLine').style.display='none';
    document.getElementById('visionBox').textContent='👁 Vision sensor standby...';
    if(visInt){clearInterval(visInt);visInt=null;}
  }
}

function captureFrame(w=640,h=480){
  if(!camActive||vid.readyState<2)return null;
  const tc=document.createElement('canvas');tc.width=w;tc.height=h;
  tc.getContext('2d').drawImage(vid,0,0,w,h);
  return tc.toDataURL('image/jpeg',.85).split(',')[1];
}

async function analyzeCamera(doSpeak=true){
  if(!camActive)return;
  const frame=captureFrame();if(!frame)return;
  const ab=document.getElementById('analyzeBtn');
  ab.classList.add('busy');ab.textContent='🔍 Scanning...';
  document.getElementById('visionBox').textContent='🔍 Analyzing...';

  const result=await callAPI([
    {type:'image',source:{type:'base64',media_type:'image/jpeg',data:frame}},
    {type:'text',text:`Analyze this camera image in detail. Identify:
- All objects, people, animals visible
- Any text or signs (read them)
- The environment/setting
- Notable details (colors, quantities, distances)
Respond naturally in 2-3 sentences as UNIT-7X robot. Reply in the conversation language (default: Filipino/English mix).`}
  ], 300);

  ab.classList.remove('busy');ab.textContent='👁 ANALYZE';

  if(result){
    document.getElementById('visionBox').textContent='👁 '+result;
    if(doSpeak){
      addVisionMsg(result);
      speak(result, detLang);
    }
  }
}

async function silentAnalyze(){
  const frame=captureFrame(320,240);if(!frame)return;
  const r=await callAPI([{type:'image',source:{type:'base64',media_type:'image/jpeg',data:frame}},{type:'text',text:'1 sentence: what do you see?'}],80);
  if(r)document.getElementById('visionBox').textContent='👁 '+r;
}

function triggerAnalysis(){
  if(!camActive){addSys('💡 Turn on the camera first!');return;}
  analyzeCamera(true);
}

