// SPEECH BUBBLE + TTS
// ══════════════════════════════════════════
let bubTO, isSpeaking=false;
function showBubble(t){
  const el=document.getElementById('speechBubble');
  el.textContent=t.length>110?t.slice(0,108)+'…':t;
  el.style.display='block';
  clearTimeout(bubTO);
  bubTO=setTimeout(()=>el.style.display='none',Math.max(4000,t.length*55));
}
function speak(text,lang='en'){
  if(!window.speechSynthesis||!text)return;
  speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(text);
  const vs=speechSynthesis.getVoices();
  let v=vs.find(x=>x.lang.toLowerCase().startsWith((lang||'en').toLowerCase()))||vs.find(x=>x.lang.startsWith('en')&&x.name.includes('Google'))||vs[0];
  if(v)u.voice=v;
  u.rate=.86;u.pitch=.52;u.volume=1;
  isSpeaking=true;setAnim('talk');
  document.getElementById('vStat').textContent='🔊 Speaking';
  u.onend=u.onerror=()=>{isSpeaking=false;setAnim('idle');document.getElementById('vStat').textContent='Ready';};
  speechSynthesis.speak(u);
  showBubble(text);
}
function stopTTS(){speechSynthesis?.cancel();isSpeaking=false;setAnim('idle');}

