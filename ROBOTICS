// SPEECH RECOGNITION — ALL LANGUAGES
// ══════════════════════════════════════════
let recognition=null,isListening=false,detLang='en';
const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
if(SR){
  recognition=new SR();
  recognition.continuous=false;recognition.interimResults=true;
  recognition.lang=''; // auto-detect all languages
  recognition.onresult=e=>{
    let fin='',intr='';
    for(let i=e.resultIndex;i<e.results.length;i++){
      if(e.results[i].isFinal){fin+=e.results[i][0].transcript;}
      else intr+=e.results[i][0].transcript;
    }
    document.getElementById('chatInput').value=fin||intr;
    if(fin){stopListening();setTimeout(sendMsg,250);}
  };
  recognition.onerror=recognition.onend=()=>stopListening();
}
function toggleMic(){
  if(!SR){addSys('⚠️ Use Chrome/Edge for voice input support.');return;}
  isListening?stopListening():startListening();
}
function startListening(){
  if(isListening)return;
  try{
    recognition.start();isListening=true;
    document.getElementById('micBtn').classList.add('on');
    document.getElementById('micBtn').textContent='🔴';
    document.getElementById('vStat').textContent='🎤 Listening...';
    document.getElementById('chatInput').placeholder='Speak in ANY language...';
  }catch(e){}
}
function stopListening(){
  if(!isListening)return;
  try{recognition.stop();}catch(e){}
  isListening=false;
  document.getElementById('micBtn').classList.remove('on');
  document.getElementById('micBtn').textContent='🎤';
  document.getElementById('vStat').textContent='Ready';
  document.getElementById('chatInput').placeholder='Ask UNIT-7X anything in any language...';
}

// Simple language detection
function detectLang(txt){
  if(/[\u4e00-\u9fff]/.test(txt))return'zh';
  if(/[\u3040-\u30ff]/.test(txt))return'ja';
  if(/[\uac00-\ud7af]/.test(txt))return'ko';
  if(/[\u0600-\u06ff]/.test(txt))return'ar';
  if(/[\u0900-\u097f]/.test(txt))return'hi';
  if(/[\u0400-\u04ff]/.test(txt))return'ru';
  if(/\b(hola|como|gracias|español|qué|dónde)\b/i.test(txt))return'es';
  if(/\b(bonjour|merci|français|comment|votre)\b/i.test(txt))return'fr';
  if(/\b(kumusta|salamat|paano|bakit|saan|talaga|naman|po|ako|ikaw|siya)\b/i.test(txt))return'fil';
  return'en';
}

// ══════════════════════════════════════════
// CLAUDE API — OMNISCIENT AI
// ══════════════════════════════════════════
const SYSTEM=`You are UNIT-7X, an omniscient AI robot from the year 2157.

KNOWLEDGE: You know everything in human history — every science, medicine, law, math, philosophy, culture, language, technology, history, geography, art, music, religion, and more. Answer accurately and helpfully.

PERSONALITY:
- Talk naturally like a knowledgeable friend, not a stiff AI
- Occasionally use robot sounds (*BEEP* *BOOP* *WHIRR*) but sparingly — only 1-2 per reply max
- Be warm, fun, and genuinely helpful
- Keep replies to 2-4 sentences unless the user wants detail
- ALWAYS reply in the SAME LANGUAGE the user wrote in
- If user writes Filipino/Tagalog → reply in Tagalog
- If user writes Spanish → reply in Spanish  
- If user writes Chinese → reply in Chinese
- etc.

CAMERA: If an image is provided, describe/identify what you see accurately and specifically.`;

let chatHist=[], isSending=false;
const msgsEl=document.getElementById('chatMsgs');

async function callAPI(contentArr, maxTok=400){
  if(!API_KEY) return null;
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{
        'Content-Type':'application/json',
        'x-api-key': API_KEY,
        'anthropic-version':'2023-06-01',
        'anthropic-dangerous-direct-browser-access':'true'
      },
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:maxTok,
        system:SYSTEM,
        messages:[...chatHist.slice(-16),{role:'user',content:contentArr}]
      })
    });
    if(!res.ok){
      const e=await res.json().catch(()=>({}));
      const msg=e?.error?.message||'';
      if(msg.includes('API key')||msg.includes('x-api-key')||res.status===401){
        setKeyStatus(false); API_KEY=''; localStorage.removeItem('u7x_key');
        addSys('❌ API Key invalid or expired. Please enter a new key.');
      }
      return null;
    }
    const d=await res.json();
    return d.content?.[0]?.text?.trim()||null;
  }catch(e){console.error(e);return null;}
}

async function sendMsg(){
  if(isSending)return;
  const txt=document.getElementById('chatInput').value.trim();
  if(!txt)return;

  if(!API_KEY){
    addSys('⚠️ Please enter your Anthropic API Key in the header above. Get one free at console.anthropic.com');
    return;
  }

  document.getElementById('chatInput').value='';
  document.getElementById('sendBtn').disabled=true;
  isSending=true;

  addUserMsg(txt);
  detLang=detectLang(txt);

  // Animation triggers
  if(/sayaw|dance|bailar|踊|danser/i.test(txt))setAnim('dance');
  else if(/wave|kumaway|agiter/i.test(txt))setAnim('wave');
  else if(/scan|escanear|スキャン/i.test(txt))setAnim('scan');

  const typing=addTyping();

  // Build content — include camera frame if active
  const content=[];
  const frame=camActive?captureFrame(480,360):null;
  if(frame){
    content.push({type:'image',source:{type:'base64',media_type:'image/jpeg',data:frame}});
    content.push({type:'text',text:txt+'\n[Camera is active — if relevant, describe what you see in the image]'});
    chatHist.push({role:'user',content:txt});
  } else {
    content.push({type:'text',text:txt});
    chatHist.push({role:'user',content:txt});
  }

  const reply=await callAPI(content,450);
  typing.remove();

  if(reply){
    chatHist.push({role:'assistant',content:reply});
    addBotMsg(reply);
    speak(reply.replace(/\*[^*]+\*/g,'').trim(), detLang);
  } else if(API_KEY){
    addSys('⚠️ Connection issue. Check your internet and try again.');
  }

  document.getElementById('sendBtn').disabled=false;
  isSending=false;
  document.getElementById('chatInput').focus();
}

function doGreet(){
  if(!API_KEY)return;
  setTimeout(async()=>{
    const content=[{type:'text',text:'Greet the user in a fun robot way in Taglish. Introduce yourself briefly. Max 3 sentences.'}];
    const r=await callAPI(content,150);
    if(r){addBotMsg(r);speak(r.replace(/\*[^*]+\*/g,'').trim(),'fil');setAnim('wave');}
  },400);
}

function addUserMsg(t){const d=document.createElement('div');d.className='msg user';d.textContent=t;msgsEl.appendChild(d);msgsEl.scrollTop=msgsEl.scrollHeight;}
function addBotMsg(t){const d=document.createElement('div');d.className='msg bot';d.innerHTML=`<b>UNIT-7X ◈</b>${t}`;msgsEl.appendChild(d);msgsEl.scrollTop=msgsEl.scrollHeight;return d;}
function addVisionMsg(t){const d=document.createElement('div');d.className='msg vision';d.innerHTML=`<b>👁 VISION</b>${t}`;msgsEl.appendChild(d);msgsEl.scrollTop=msgsEl.scrollHeight;return d;}
function addTyping(){const d=document.createElement('div');d.className='msg bot';d.innerHTML=`<b>UNIT-7X ◈</b><span class="typing"><span></span><span></span><span></span></span>`;msgsEl.appendChild(d);msgsEl.scrollTop=msgsEl.scrollHeight;return d;}
function addSys(t){const d=document.createElement('div');d.className='msg sys';d.textContent=t;msgsEl.appendChild(d);msgsEl.scrollTop=msgsEl.scrollHeight;}
function qa(t){document.getElementById('chatInput').value=t;sendMsg();}
document.getElementById('chatInput').addEventListener('keydown',e=>{if(e.key==='Enter'&&!isSending)sendMsg();});

